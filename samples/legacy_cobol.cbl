       IDENTIFICATION DIVISION.
       PROGRAM-ID. PAYROLL-CALC.
       AUTHOR. LEGACY-SYSTEM.
       DATE-WRITTEN. 1985-03-15.

       ENVIRONMENT DIVISION.
       INPUT-OUTPUT SECTION.
       FILE-CONTROL.
           SELECT EMPLOYEE-FILE ASSIGN TO 'EMPLOYEES.DAT'
               ORGANIZATION IS LINE SEQUENTIAL.
           SELECT REPORT-FILE ASSIGN TO 'PAYROLL.RPT'
               ORGANIZATION IS LINE SEQUENTIAL.

       DATA DIVISION.
       FILE SECTION.
       FD EMPLOYEE-FILE.
       01 EMPLOYEE-RECORD.
          05 EMP-ID         PIC 9(6).
          05 EMP-NAME       PIC X(30).
          05 EMP-HOURS      PIC 9(3).
          05 EMP-RATE       PIC 9(5)V99.
          05 EMP-DEPT       PIC X(10).

       FD REPORT-FILE.
       01 REPORT-LINE        PIC X(80).

       WORKING-STORAGE SECTION.
       01 WS-EOF             PIC X VALUE 'N'.
       01 WS-GROSS-PAY       PIC 9(7)V99.
       01 WS-TAX             PIC 9(7)V99.
       01 WS-NET-PAY         PIC 9(7)V99.
       01 WS-TOTAL-PAYROLL   PIC 9(9)V99 VALUE 0.
       01 WS-EMP-COUNT       PIC 9(5) VALUE 0.
       01 WS-TAX-RATE        PIC V99 VALUE .25.
       01 WS-OVERTIME-RATE   PIC V9(3) VALUE 1.5.
       01 WS-STANDARD-HOURS  PIC 9(3) VALUE 40.
       01 WS-OVERTIME-HOURS  PIC 9(3).
       01 WS-REGULAR-PAY     PIC 9(7)V99.
       01 WS-OVERTIME-PAY    PIC 9(7)V99.

       PROCEDURE DIVISION.
       MAIN-PARAGRAPH.
           OPEN INPUT EMPLOYEE-FILE.
           OPEN OUTPUT REPORT-FILE.
           PERFORM READ-EMPLOYEE.
           PERFORM UNTIL WS-EOF = 'Y'
               PERFORM CALCULATE-PAY
               PERFORM WRITE-REPORT-LINE
               ADD WS-GROSS-PAY TO WS-TOTAL-PAYROLL
               ADD 1 TO WS-EMP-COUNT
               PERFORM READ-EMPLOYEE
           END-PERFORM.
           PERFORM WRITE-SUMMARY.
           CLOSE EMPLOYEE-FILE.
           CLOSE REPORT-FILE.
           STOP RUN.

       READ-EMPLOYEE.
           READ EMPLOYEE-FILE INTO EMPLOYEE-RECORD
               AT END MOVE 'Y' TO WS-EOF.

       CALCULATE-PAY.
           IF EMP-HOURS > WS-STANDARD-HOURS
               SUBTRACT WS-STANDARD-HOURS FROM EMP-HOURS
                   GIVING WS-OVERTIME-HOURS
               MULTIPLY WS-STANDARD-HOURS BY EMP-RATE
                   GIVING WS-REGULAR-PAY
               MULTIPLY WS-OVERTIME-HOURS BY EMP-RATE
                   GIVING WS-OVERTIME-PAY
               MULTIPLY WS-OVERTIME-PAY BY WS-OVERTIME-RATE
                   GIVING WS-OVERTIME-PAY
               ADD WS-REGULAR-PAY WS-OVERTIME-PAY
                   GIVING WS-GROSS-PAY
           ELSE
               MULTIPLY EMP-HOURS BY EMP-RATE
                   GIVING WS-GROSS-PAY
               MOVE 0 TO WS-OVERTIME-HOURS.
           MULTIPLY WS-GROSS-PAY BY WS-TAX-RATE
               GIVING WS-TAX.
           SUBTRACT WS-TAX FROM WS-GROSS-PAY
               GIVING WS-NET-PAY.

       WRITE-REPORT-LINE.
           MOVE SPACES TO REPORT-LINE.
           STRING EMP-ID DELIMITED SIZE
                  ' ' DELIMITED SIZE
                  EMP-NAME DELIMITED SIZE
                  ' GROSS:' DELIMITED SIZE
                  WS-GROSS-PAY DELIMITED SIZE
                  ' NET:' DELIMITED SIZE
                  WS-NET-PAY DELIMITED SIZE
               INTO REPORT-LINE.
           WRITE REPORT-LINE.

       WRITE-SUMMARY.
           MOVE SPACES TO REPORT-LINE.
           STRING 'TOTAL EMPLOYEES: ' DELIMITED SIZE
                  WS-EMP-COUNT DELIMITED SIZE
                  ' TOTAL PAYROLL: ' DELIMITED SIZE
                  WS-TOTAL-PAYROLL DELIMITED SIZE
               INTO REPORT-LINE.
           WRITE REPORT-LINE.
